<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                  xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  id="Definitions_1"
                  targetNamespace="http://bpmn.io/schema/bpmn"
                  exporter="Camunda Modeler"
                  exporterVersion="5.20.0">

  <bpmn:process id="lead-lifecycle" name="Lead Lifecycle Process" isExecutable="true">

    <bpmn:startEvent id="StartEvent_LeadCreated" name="Lead Created">
    </bpmn:startEvent>

    <bpmn:userTask id="Task_ContactCustomer" name="Liên hệ khách hàng">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="lead-contact-form" />
        <zeebe:assignmentDefinition assignee="=ownerId" />
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_ContactResult" name="Kết quả liên hệ?">
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_ProcessLead" name="Xử lý cơ hội">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="lead-process-form" />
        <zeebe:assignmentDefinition assignee="=ownerId" />
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:serviceTask id="Task_UpdateStatus" name="Cập nhật trạng thái">
      <bpmn:extensionElements>
        <zeebe:taskDefinition type="lead-status-change" />
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:userTask id="Task_CollectDocuments" name="Thu thập hồ sơ">
      <bpmn:extensionElements>
        <zeebe:formDefinition formKey="lead-document-form" />
        <zeebe:assignmentDefinition assignee="=ownerId" />
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_Completed" name="Hoàn thành">
    </bpmn:endEvent>

    <bpmn:endEvent id="EndEvent_Rejected" name="KH từ chối">
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Start_Contact" sourceRef="StartEvent_LeadCreated" targetRef="Task_ContactCustomer" />
    <bpmn:sequenceFlow id="Flow_Contact_Gateway" sourceRef="Task_ContactCustomer" targetRef="Gateway_ContactResult" />
    <bpmn:sequenceFlow id="Flow_Gateway_Process" name="Quan tâm" sourceRef="Gateway_ContactResult" targetRef="Task_ProcessLead">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=contactResult = "INTERESTED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gateway_Rejected" name="Từ chối" sourceRef="Gateway_ContactResult" targetRef="EndEvent_Rejected">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=contactResult = "REJECTED"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Process_Documents" sourceRef="Task_ProcessLead" targetRef="Task_CollectDocuments" />
    <bpmn:sequenceFlow id="Flow_Documents_Status" sourceRef="Task_CollectDocuments" targetRef="Task_UpdateStatus" />
    <bpmn:sequenceFlow id="Flow_Status_End" sourceRef="Task_UpdateStatus" targetRef="EndEvent_Completed" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="lead-lifecycle">
      <bpmndi:BPMNShape id="_BPMNShape_StartEvent_1" bpmnElement="StartEvent_LeadCreated">
        <dc:Bounds x="179" y="199" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="163" y="242" width="68" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ContactCustomer_di" bpmnElement="Task_ContactCustomer">
        <dc:Bounds x="270" y="177" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ContactResult_di" bpmnElement="Gateway_ContactResult" isMarkerVisible="true">
        <dc:Bounds x="425" y="192" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="408" y="162" width="84" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_ProcessLead_di" bpmnElement="Task_ProcessLead">
        <dc:Bounds x="540" y="177" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_CollectDocuments_di" bpmnElement="Task_CollectDocuments">
        <dc:Bounds x="700" y="177" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_UpdateStatus_di" bpmnElement="Task_UpdateStatus">
        <dc:Bounds x="860" y="177" width="100" height="80" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Completed_di" bpmnElement="EndEvent_Completed">
        <dc:Bounds x="1022" y="199" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1008" y="242" width="64" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="432" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="420" y="365" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Contact_di" bpmnElement="Flow_Start_Contact">
        <di:waypoint x="215" y="217" />
        <di:waypoint x="270" y="217" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Contact_Gateway_di" bpmnElement="Flow_Contact_Gateway">
        <di:waypoint x="370" y="217" />
        <di:waypoint x="425" y="217" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gateway_Process_di" bpmnElement="Flow_Gateway_Process">
        <di:waypoint x="475" y="217" />
        <di:waypoint x="540" y="217" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="485" y="199" width="48" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Gateway_Rejected_di" bpmnElement="Flow_Gateway_Rejected">
        <di:waypoint x="450" y="242" />
        <di:waypoint x="450" y="322" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="456" y="273" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Process_Documents_di" bpmnElement="Flow_Process_Documents">
        <di:waypoint x="640" y="217" />
        <di:waypoint x="700" y="217" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Documents_Status_di" bpmnElement="Flow_Documents_Status">
        <di:waypoint x="800" y="217" />
        <di:waypoint x="860" y="217" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Status_End_di" bpmnElement="Flow_Status_End">
        <di:waypoint x="960" y="217" />
        <di:waypoint x="1022" y="217" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
